{
  "name": "@dashlight/server",
  "version": "1.0.0-rc.2",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --env-file=../../.env --import tsx/esm --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "hono": "^4.12.23",
    "jose": "^6.2.3",
    "js-yaml": "^4.1.1",
    "lru-cache": "^11.5.0",
    "undici": "^8.3.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "tsx": "^4.22.3",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
